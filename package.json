{
  "name": "bcm-testbuilder",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "main": "electron/main.cjs",
  "build": {
    "appId": "com.bromcom.desktop",
    "productName": "Bromcom Test Builder",
    "directories": {
      "buildResources": "electron/assets"
    },
    "win": {
      "icon": "electron/assets/app-icon.ico"
    },
    "linux": {
      "icon": "electron/assets/brand-logo.png"
    }
  },
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "lint": "eslint .",
    "preview": "vite preview",
    "electron:dev": "node electron/dev-runner.cjs",
    "electron:start": "npm run build && electron ."
  },
  "dependencies": {
    "@emotion/react": "^11.14.0",
    "@emotion/styled": "^11.14.1",
    "@mui/material": "^9.0.0",
    "materialize-css": "^1.0.0",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "uuid": "^9.0.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.4",
    "@types/materialize-css": "^1.0.9",
    "@types/node": "^24.12.2",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@types/uuid": "^10.0.0",
    "@vitejs/plugin-react": "^6.0.1",
    "electron": "^41.2.0",
    "eslint": "^9.39.4",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "globals": "^17.4.0",
    "sass": "^1.69.5",
    "typescript": "~6.0.2",
    "typescript-eslint": "^8.58.0",
    "vite": "^8.0.4"
  }
}
